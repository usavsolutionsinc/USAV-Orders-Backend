{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "git": {
    "deploymentEnabled": false
  },
  "crons": [
    {
      "path": "/api/cron/workflow-node-stats",
      "schedule": "45 0 * * *"
    },
    {
      "path": "/api/cron/shipping/sync-due?limit=150&concurrency=8",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/cron/shipping/sync-due?limit=200&concurrency=8&carriers=UPS,FEDEX",
      "schedule": "0 0 * * 2-6"
    },
    {
      "path": "/api/cron/shipping/reconcile-delivered",
      "schedule": "20 * * * *"
    },
    {
      "path": "/api/cron/shipping/metrics",
      "schedule": "*/30 * * * *"
    },
    {
      "path": "/api/cron/receiving/incoming-tracking-sync",
      "schedule": "10,25,40,55 * * * *"
    },
    {
      "path": "/api/cron/zoho/incoming-po-sync",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/cron/zoho/po-sync?mode=delta",
      "schedule": "7,22,37,52 * * * *"
    },
    {
      "path": "/api/cron/zoho/po-sync?mode=full",
      "schedule": "30 3 * * *"
    },
    {
      "path": "/api/cron/zoho/fulfillment-sync?mode=delta",
      "schedule": "15 */4 * * *"
    },
    {
      "path": "/api/cron/zoho/fulfillment-sync?mode=full",
      "schedule": "45 3 * * *"
    },
    {
      "path": "/api/cron/zoho/orders-ingest-drain",
      "schedule": "* * * * *"
    },
    {
      "path": "/api/cron/amazon/orders-sync",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/cron/google-sheets/transfer-orders",
      "schedule": "30 15 * * 1-5"
    },
    {
      "path": "/api/cron/google-sheets/transfer-orders",
      "schedule": "0 18 * * 1-5"
    },
    {
      "path": "/api/cron/google-sheets/transfer-orders",
      "schedule": "0 22 * * 1-5"
    },
    {
      "path": "/api/cron/staff-goals/history",
      "schedule": "30 0 * * *"
    },
    {
      "path": "/api/cron/replenishment/sync",
      "schedule": "0 13 * * *"
    },
    {
      "path": "/api/cron/replenishment-detect",
      "schedule": "0 */4 * * *"
    },
    {
      "path": "/api/cron/inventory/drift-check",
      "schedule": "0 11 * * *"
    },
    {
      "path": "/api/cron/stock-alerts",
      "schedule": "0 14 * * *"
    },
    {
      "path": "/api/cron/sourcing/scan",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/cron/sourcing/replenish",
      "schedule": "0 7 * * *"
    },
    {
      "path": "/api/cron/sourcing/scour",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/cron/sku-catalog/refresh-suggestions",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/cron/refresh-reports",
      "schedule": "30 10 * * *"
    },
    {
      "path": "/api/cron/ebay/refresh-tokens",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/integrations/sync?providers=ebay,square",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/cron/cleanup",
      "schedule": "0 5 * * *"
    }
  ]
}
