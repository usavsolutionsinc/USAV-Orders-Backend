import { NextRequest, NextResponse } from 'next/server';
import pool from '@/lib/db';
import { withAuth } from '@/lib/auth/withAuth';
import { ApiError, errorResponse } from '@/lib/api';
import { recordAudit } from '@/lib/audit-logs';

export const dynamic = 'force-dynamic';

interface SettingsRow {
  auto_delete_enabled: boolean;
  auto_delete_after_days: number;
  last_cron_run_at: string | null;
  last_cron_summary: unknown;
  needs_reconnect: boolean;
  needs_reconnect_reason: string | null;
  updated_at: string;
}

export const GET = withAuth(async () => {
  try {
    const { rows } = await pool.query<SettingsRow>(
      `SELECT auto_delete_enabled, auto_delete_after_days, last_cron_run_at,
              last_cron_summary, needs_reconnect, needs_reconnect_reason, updated_at
       FROM google_photos_settings WHERE id = 1`,
    );
    const row = rows[0] ?? null;
    return NextResponse.json({
      autoDeleteEnabled: row?.auto_delete_enabled ?? false,
      autoDeleteAfterDays: row?.auto_delete_after_days ?? 30,
      lastCronRunAt: row?.last_cron_run_at ?? null,
      lastCronSummary: row?.last_cron_summary ?? null,
      needsReconnect: row?.needs_reconnect ?? false,
      needsReconnectReason: row?.needs_reconnect_reason ?? null,
      updatedAt: row?.updated_at ?? null,
    });
  } catch (error) {
    return errorResponse(error, 'GET /api/admin/google-photos/settings');
  }
}, { permission: 'admin.view' });

export const POST = withAuth(async (req: NextRequest, ctx) => {
  try {
    const body = await req.json().catch(() => null);
    if (!body || typeof body !== 'object') {
      throw ApiError.badRequest('Invalid JSON body');
    }
    const autoDeleteEnabled = Boolean(body.autoDeleteEnabled);
    const autoDeleteAfterDays = Math.min(365, Math.max(1, Math.floor(Number(body.autoDeleteAfterDays) || 30)));

    await pool.query(
      `UPDATE google_photos_settings
         SET auto_delete_enabled = $1,
             auto_delete_after_days = $2
       WHERE id = 1`,
      [autoDeleteEnabled, autoDeleteAfterDays],
    );

    await recordAudit(pool, ctx, req, {
      action: 'google_photos.settings_updated',
      method: 'admin',
      extra: { auto_delete_enabled: autoDeleteEnabled, auto_delete_after_days: autoDeleteAfterDays },
    });

    return NextResponse.json({ success: true, autoDeleteEnabled, autoDeleteAfterDays });
  } catch (error) {
    return errorResponse(error, 'POST /api/admin/google-photos/settings');
  }
}, { permission: 'admin.view' });
