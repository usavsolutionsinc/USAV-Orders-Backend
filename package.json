    "fba:backfill-shipment-refs": "node scripts/fba-backfill-shipment-refs.js",
    "pipeline:start": "pm2 start ecosystem.config.cjs",
    "pipeline:stop": "pm2 stop pipeline",
    "pipeline:logs": "pm2 logs pipeline --lines 100",
    "pipeline:status": "curl -s http://localhost:3000/api/pipeline/status | npx json",
    "pipeline:trigger": "curl -s -X POST http://localhost:3000/api/pipeline/trigger | npx json",
    "pipeline:orchestrator": "NODE_OPTIONS='--max-old-space-size=4096' tsx src/lib/pipeline/orchestrator.ts",
    "pipeline:migrate": "node scripts/migrate-pipeline-tables.mjs",
    "pipeline:test": "node scripts/e2e-pipeline.mjs",
    "pipeline:test:api": "node scripts/e2e-pipeline.mjs --with-api",
    "diagrams:modules": "depcruise src --include-only ^src --config .dependency-cruiser.cjs --collapse \"^src/(app|components|lib|domain|hooks|utils|server|services)/[^/]+\" --output-type mermaid --output-to docs/diagrams/05-module-graph.mmd",
    "diagrams:md": "depcruise src --include-only ^src --config .dependency-cruiser.cjs --collapse \"^src/(app|components|lib|domain|hooks|utils|server|services)/[^/]+\" --output-type mermaid --output-to docs/diagrams/05-module-graph.md",
    "diagrams:archi": "depcruise src --include-only ^src --config .dependency-cruiser.cjs --output-type archi --output-to docs/diagrams/06-architecture.dot",
    "diagrams:html": "depcruise src --include-only ^src --config .dependency-cruiser.cjs --output-type err-html --output-to docs/diagrams/dep-report.html",
    "diagrams:check": "depcruise src --include-only ^src --config .dependency-cruiser.cjs",
    "diagrams": "npm run diagrams:modules",
    "dead-code:knip": "npx knip --reporter compact",
    "dead-code:report": "node scripts/generate-dead-code-report.mjs",
    "dead-code:depcruise": "npx depcruise src --config .dependency-cruiser.cjs --output-type text | head -100"
  },
