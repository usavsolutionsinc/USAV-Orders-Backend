    "debug:transfer-order": "node scripts/debug-transfer-order-match.js",
    "check:mobile-endpoints": "node scripts/check-mobile-endpoint-integrity.js",
    "sync:repair-incoming-ecwid": "node scripts/sync-ecwid-incoming-repairs.js",
    "qstash:ensure:google-sheets": "node scripts/ensure-google-sheets-qstash-schedules.js",
    "qstash:sync": "node scripts/sync-qstash-schedules.js",
    "staff-goals:history:backfill": "node scripts/backfill-staff-goal-history.js",
    "sync:packer-logs": "node sync-packer-sheets-to-logs.js",
    "sync:packer-logs:preview": "node sync-packer-sheets-to-logs-dry-run.js",
