{
  "name": "usav-orders",
  "version": "0.1.0",
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "dev": "next dev",
    "build": "NODE_OPTIONS='--max-old-space-size=4096' next build --webpack",
    "start": "next start",
    "vercel:env:push": "node scripts/push-vercel-env.js",
    "desktop:dev": "node scripts/electron-dev.js",
    "desktop:start": "electron .",
    "desktop:dist": "electron-builder",
    "desktop:dist:mac": "electron-builder --mac dmg",
    "desktop:dist:win": "electron-builder --win nsis",
    "lint": "next lint",
    "db:studio": "drizzle-kit studio",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "realtime:relay": "node scripts/realtime-outbox-relay.js",
    "sync:packer-logs": "node sync-packer-sheets-to-logs.js",
    "sync:packer-logs:preview": "node sync-packer-sheets-to-logs-dry-run.js"
  },
  "build": {
    "appId": "com.usav.orders.desktop",
    "productName": "USAV Orders",
    "asar": true,
    "directories": {
      "output": "desktop-dist"
    },
    "files": [
      "electron/**/*",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.business",
      "target": [
        "dmg"
      ]
    },
    "win": {
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.0.2",
    "@tanstack/react-query": "^5.0.0",
    "@types/nodemailer": "^7.0.5",
    "@upstash/qstash": "^2.9.0",
    "@upstash/redis": "^1.36.2",
    "@vercel/blob": "^0.27.0",
    "ably": "^2.19.0",
    "canvas-confetti": "^1.9.4",
    "dotenv": "^17.2.3",
    "drizzle-kit": "^0.31.8",
    "drizzle-orm": "^0.45.1",
    "ebay-api": "^9.4.0",
    "framer-motion": "^11.0.0",
    "googleapis": "^169.0.0",
    "html5-qrcode": "^2.3.8",
    "next": "^16.0.7",
    "nodemailer": "^7.0.12",
    "pg": "^8.16.3",
    "postgres": "^3.4.7",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "sonner": "^2.0.7"
  },
  "devDependencies": {
    "@types/canvas-confetti": "^1.9.0",
    "@types/node": "^20",
    "@types/pg": "^8.15.6",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "autoprefixer": "^10.4.17",
    "baseline-browser-mapping": "^2.9.19",
    "concurrently": "^9.2.1",
    "electron": "^41.0.1",
    "electron-builder": "^26.8.1",
    "eslint": "^9.39.1",
    "eslint-config-next": "^16.0.7",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "typescript": "^5",
    "vercel": "^32.3.0",
    "wait-on": "^9.0.4"
  }
}
