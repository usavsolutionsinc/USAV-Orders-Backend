    "start": "next start",
    "vercel:env:push": "node scripts/push-vercel-env.js",
    "desktop:dev": "node scripts/electron-dev.js",
    "desktop:start": "electron .",
    "desktop:dist": "electron-builder",
    "desktop:dist:mac": "electron-builder --mac dmg",
    "desktop:dist:mac-intel-legacy": "electron-builder --mac dmg --x64 --config electron-builder.mac-intel-legacy.yml",
    "desktop:dist:win": "electron-builder --win nsis --x64",
    "desktop:upload": "node scripts/upload-desktop-installers.mjs",
    "manuals:convert-upload": "node scripts/convert-and-upload-manuals.mjs",
    "manuals:backfill-db": "node scripts/backfill-manual-blob-urls.mjs",
