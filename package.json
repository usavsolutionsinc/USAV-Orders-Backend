    "db:migrate": "node scripts/run-pending-migrations.mjs",
    "db:migrate:dry": "node scripts/run-pending-migrations.mjs --dry",
    "db:migrate:product-manuals": "node scripts/create-product-manuals-table.js",
    "db:migrate:station-sessions": "node scripts/migrate-station-scan-sessions.mjs",
    "db:migrate:tsn-context-sal": "node scripts/add-tech-serial-context-sal-column.mjs",
