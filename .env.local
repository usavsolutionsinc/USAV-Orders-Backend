# .env.local is not used - all environment variables are in .env for local testing
# This file is kept empty to prevent conflicts with .env

# Pinless rollout: set AUTH_PINLESS_SIGNIN=true so staff can sign in by
# tapping their name without a PIN. Flip to "false" (or remove) to restore
# the PIN gate. See src/app/api/auth/signin/route.ts for the gate logic.
AUTH_PINLESS_SIGNIN=true
