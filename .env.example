MANUAL_SERVER_API_KEY=

# Vercel Blob Storage
BLOB_READ_WRITE_TOKEN=

# NocoDB API Token
NOCODB_API_TOKEN=

# Zoho Integration
ZOHO_ORG_ID=
ZOHO_DOMAIN=
