ZendeskTicketMailer_GAS_WebappURL=
APPS_SCRIPT_WEBAPP_URL=

# Google Sheets & Service Account
GOOGLE_CLIENT_EMAIL=
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_PRIVATE_KEY=

# Neon Postgres Database (Primary)
DATABASE_URL_UNPOOLED=
PGHOST=
POSTGRES_USER=
DATABASE_URL=
POSTGRES_PASSWORD=
POSTGRES_DATABASE=
PGPASSWORD=
PGDATABASE=
PGHOST_UNPOOLED=
PGUSER=
POSTGRES_URL_NO_SSL=
POSTGRES_HOST=
NEON_PROJECT_ID=
POSTGRES_URL=

# Local manual server bridge
