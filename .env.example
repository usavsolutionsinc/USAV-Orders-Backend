# ===================================
# eBay API Configuration
# ===================================
EBAY_APP_ID=
EBAY_CERT_ID=
EBAY_RU_NAME=
EBAY_ENVIRONMENT=

# eBay Account Tokens - USAV
EBAY_REFRESH_TOKEN_USAV=
EBAY_ACCESS_TOKEN_USAV=

# Ecwid Integration
ECWID_STORE_ID=
ECWID_API_TOKEN=

QSTASH_CURRENT_SIGNING_KEY=
QSTASH_NEXT_SIGNING_KEY=
QSTASH_TOKEN=
QSTASH_URL=

KV_REST_API_READ_ONLY_TOKEN=
KV_REST_API_TOKEN=
KV_REST_API_URL=
KV_URL=
REDIS_URL=

# ===================================
# Ably Realtime Configuration
# ===================================
# Server-only key from Ably dashboard (do NOT expose to client)
ABLY_API_KEY=

# Public app URL used by the client to request Ably token auth
NEXT_PUBLIC_APP_URL=
NEXT_PUBLIC_ABLY_AUTH_PATH=

AI_CHAT_RATE_LIMIT=
AI_SEARCH_RATE_LIMIT=

WALMART_CLIENT_ID=
WALMART_CLIENT_SECRET=

# USPS API Configuration
CONSUMER_KEY=
CONSUMER_SECRET=

# UPS API Configuration
UPS_CLIENT_ID=
UPS_CLIENT_SECRET=

# FedEx API Configuration
FEDEX_CLIENT_ID=
FEDEX_CLIENT_SECRET=
FEDEX_ENV=

# ===================================
# AI Training Pipeline
# ===================================

# MLX LM server (local inference on Mac)
MLX_BASE_URL=
MLX_MODEL=

# Pipeline orchestrator
PIPELINE_REPO_PATH=
PIPELINE_CYCLE_SEC=
PIPELINE_MAX_TASKS=
PIPELINE_MAX_IMPL=
PIPELINE_MAX_ATTEMPTS=
PIPELINE_RUN_BUILD=
PIPELINE_ADAPTER_DIR=

# Training (Jetson reads these same values via /etc/jetson-trainer.env)
PIPELINE_BASE_MODEL=
PIPELINE_MIN_SAMPLES=
PIPELINE_RATING_THRESHOLD=

# ===================================
# Feature Flags
# ===================================
FEATURE_REPLENISHMENT=
# Fulfillment substitution (ordered-vs-fulfilled amendments; order_unit_amendments).
# Gates POST /api/orders/[id]/substitute + the station SubstituteUnitCard mounts.
# Default OFF; requires migration 2026-06-27e_order_unit_amendments. Set =true to enable.
FULFILLMENT_SUBSTITUTION=

# ===================================
# OpenClaw Gateway (single tunnel — handles all AI model routing)
# Cloudflare tunnel: ai.michaelgarisek.com → WSL OpenClaw (:18789)
# OpenClaw routes internally to Ollama, LM Studio, NemoClaw RAG, etc.
# ===================================
OPENCLAW_GATEWAY_URL=
OPENCLAW_USAV_TOKEN=

# NemoClaw RAG (Bose service manuals — via Cloudflare tunnel)
# Tunnel: rag.michaelgarisek.com → WSL NemoClaw (:8765)
NEMOCLAW_RAG_URL=

# Local Hermes gateway (replaces OPENCLAW_GATEWAY_URL for /api/ai/*)
# PM2 app: hermes-gateway. OpenAI-compatible, binds 127.0.0.1:8642.
HERMES_API_URL=

HERMES_API_KEY=

# Default model the app sends to the Hermes gateway. Used by every
# server-side AI call (PO-mailbox extraction, future automation tasks).
# Must match a model loaded in the local Hermes runtime:
#   curl -s http://127.0.0.1:8642/v1/models | jq '.data[].id'
AI_MODEL=

GOOGLE_PHOTOS_CLIENT_SECRET=

GOOGLE_PHOTOS_CLIENT_ID=

PO_GMAIL_CLIENT_SECRET=

PO_GMAIL_CLIENT_ID=

CRON_SECRET=

LABEL_QR_BASE_URL=

NEXT_PUBLIC_LABEL_QR_BASE_URL=

ZENDESK_SUBDOMAIN=
ZENDESK_EMAIL=
ZENDESK_API_TOKEN=

STRIPE_PB_TEST_KEY=
STRIPE_SK_TEST_KEY=

STRIPE_WEBHOOK_SECRET=
# ─── Amazon SP-API (added 2026-06-14 — fill in values) ──────────────────────
# App-level SP-API app + LWA credentials (shared across tenants).
AMAZON_APP_ID=
AMAZON_LWA_CLIENT_ID=
AMAZON_LWA_CLIENT_SECRET=
AMAZON_OAUTH_REDIRECT_URI=
# Set to "true" while the SP-API app is in DRAFT (adds &version=beta to consent URL).
AMAZON_APP_DRAFT=
# USAV bootstrap fallback: self-authorized refresh token + region/marketplaces.
AMAZON_SP_API_REFRESH_TOKEN_USAV=
AMAZON_SP_API_REGION=
AMAZON_MARKETPLACE_IDS=
# ─── Nango (Square hosted Connect) ──────────────────────────────────────────
NANGO_SECRET_KEY=
NEXT_PUBLIC_NANGO_CONNECT_BASE_URL=
NEXT_PUBLIC_NANGO_API_URL=

# ── eBay connect / integration encryption (added 2026-06-14) ──
# AES-256-GCM master key for the integration vault (eBay/Amazon/etc tokens + OAuth state).
# REQUIRED in production (app hard-fails without it). Must be the SAME value in Vercel.
INTEGRATION_KMS_KEY=
# Optional: space-separated OAuth scope override (defaults set in src/lib/ebay/oauth-config.ts).
# Add sell.finances only once the eBay app is approved for it.
# EBAY_SCOPES=https://api.ebay.com/oauth/api_scope https://api.ebay.com/oauth/api_scope/sell.inventory https://api.ebay.com/oauth/api_scope/sell.fulfillment https://api.ebay.com/oauth/api_scope/sell.account

# ── Staff sign-in (added 2026-06-17) ──
# Pinless staff sign-in: empty/missing PIN signs the staff in by name alone
# (active status still required); audited as `signin.pinless`. Read by
# src/app/api/auth/{signin,staff-picker}/route.ts. Accepts true/1/on/yes.
# Temporary rollout measure — set false to restore the PIN gate.
AUTH_PINLESS_SIGNIN=
